# .env.example — copy to .env and fill in your values
# Never commit your actual .env file to version control.

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id
VERIFY_TOKEN=your_webhook_verify_token

# --- Google Sheets (optional, for ops logging) ---
GSHEET_ID=your_google_sheet_id
GSHEET_TAB=Sheet1
GOOGLE_CREDS_JSON_B64=base64_encoded_service_account_json

# --- Database ---
DATABASE_URL=sqlite:///./chatlog.db

# --- RAG tuning ---
TRANSCRIPT_TOP_K=6
TRANSCRIPT_MAX_CHUNKS=800
RAG_MIN_SCORE=0.25
MIN_CHARS_PER_CHUNK=1400
MAX_CHARS_PER_CHUNK=2400
CHUNK_OVERLAP_CHARS=200

# --- Campaign scripts ---
BOT_BASE_URL=https://your-deployment-url.com
WHATSAPP_RECIPIENT=15551234567   # test phone number (no +)
TEMPLATE_NAME=your_template_name
TEMPLATE_LANG=en
